{
  "manifest_version": 3,
  "name": "Shadow AI Radar",
  "version": "1.0.2",
  "description": "Local-first AI DLP: detect PII, secrets, and confidential data before prompts are sent to ChatGPT or Claude.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Shadow AI Radar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["lib/detectors.js", "lib/risk-engine.js", "content/warning.js", "content/chatgpt.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["lib/detectors.js", "lib/risk-engine.js", "content/warning.js", "content/claude.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
